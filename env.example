# Copy to `.env` for local runs. On Streamlit Cloud, put these in the app's
# Secrets instead (Settings -> Secrets), which uses the same names.

# --- Claude (required: this app is the write-up) ---
# https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=

# --- Alpaca (optional: live last-trade prices) ---
# Without these the brief still runs, using the scan's own prices, which are as
# old as the last scan. Free signup: https://alpaca.markets/ (paper keys are fine
# -- data access is identical).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# "iex" (default, free) or "sip" (needs entitlement; requesting it without one 403s).
ALPACA_DATA_FEED=iex

# --- Where the scan comes from (optional) ---
# Defaults to the strat-alerts repo's published latest_scan.json. Override to
# point at a fork or a branch.
# SCAN_URL=https://raw.githubusercontent.com/yomerosho/strat-alerts/main/latest_scan.json
