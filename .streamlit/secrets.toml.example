# Template for Streamlit Cloud. Copy the contents into the app's
# Settings -> Secrets box (paste the values, not this file).
#
# Locally you don't need this at all -- use .env instead. If you do create a
# real .streamlit/secrets.toml it is gitignored, but .env is the simpler path.
#
# Same names as .env; _secret() in app.py checks st.secrets first, then env.

# --- required: this app is the write-up ---
ANTHROPIC_API_KEY = "sk-ant-..."

# --- strongly recommended once deployed ---
# Without this the app is open to anyone with the URL, and every Generate
# spends your Anthropic credits. Any non-empty string works.
APP_PASSWORD = "pick-something-long"

# --- optional: live last-trade prices ---
# Omit and the brief runs off the scan's own prices, and says so on the page.
ALPACA_API_KEY = ""
ALPACA_SECRET_KEY = ""
ALPACA_DATA_FEED = "iex"

# --- optional: point at a different scan ---
# SCAN_URL = "https://raw.githubusercontent.com/yomerosho/strat-alerts/main/latest_scan.json"
